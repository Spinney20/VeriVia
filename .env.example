# PostgreSQL connection string (Neon free tier)
# Get this from: https://neon.tech → Project → Connection Details
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# JWT secret for token signing (REQUIRED in production, auto-generated in dev)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# ─── Build notes ───
# sqlx macros (query!, query_as!) verify queries against a real database at compile time.
# You need DATABASE_URL set when running `cargo build`.
#
# For offline builds (CI/CD), first generate the cache on a machine with DB access:
#   cargo sqlx prepare --workspace
# Then set SQLX_OFFLINE=true on the build machine.
